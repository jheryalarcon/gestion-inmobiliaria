generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Usuario {
  id                            Int                  @id @default(autoincrement())
  name                          String
  email                         String               @unique
  password                      String
  rol                           Rol
  createdAt                     DateTime             @default(now())
  activo                        Boolean              @default(true)
  telefono                      String?
  updatedAt                     DateTime             @updatedAt
  token_verificacion            String?
  verificado                    Boolean              @default(false)
  cedula                        String?              @unique
  direccion                     String?
  token_recuperacion            String?
  token_recuperacion_expiracion DateTime?
  token_verificacion_expiracion DateTime?
  archivosNegociacion           ArchivoNegociacion[]
  clientes                      Cliente[]
  clientes_desactivados         Cliente[]            @relation("ClienteDesactivador")
  documentos                    DocumentoAgente[]
  favoritos                     Favorito[]
  interacciones                 InteraccionUsuario[]
  negociaciones                 Negociacion[]
  notasInternas                 NotaInterna[]
  propiedades                   Propiedad[]
  propiedades_desactivadas      Propiedad[]          @relation("PropiedadDesactivador")
  propiedades_actualizadas      Propiedad[]          @relation("PropiedadActualizador")
  seguimientos                  Seguimiento[]
}

model Propiedad {
  id                       Int                    @id @default(autoincrement())
  titulo                   String
  descripcion              String?
  tipo_propiedad           TipoPropiedad
  estado_propiedad         EstadoFisico
  transaccion              TipoTransaccion
  precio                   Decimal                @db.Decimal(12, 2)
  moneda                   String                 @default("USD")
  direccion                String
  ciudad                   String
  provincia                Provincia
  pais                     String                 @default("Ecuador")
  codigo_postal            String?
  latitud                  Decimal?               @db.Decimal(10, 7)
  longitud                 Decimal?               @db.Decimal(10, 7)
  area_terreno             Decimal                @db.Decimal(10, 2)
  area_construccion        Decimal?               @db.Decimal(10, 2)
  nro_habitaciones         Int?
  nro_banos                Int?
  nro_parqueaderos         Int?
  nro_pisos                Int?
  anio_construccion        Int?
  estado_publicacion       EstadoPropiedad        @default(disponible)
  agenteId                 Int
  createdAt                DateTime               @default(now())
  updatedAt                DateTime               @updatedAt
  amoblado                 Boolean                @default(false)
  codigo_interno           String?                @unique
  comision                 Decimal?               @db.Decimal(10, 2)
  desactivado_por          Int?
  fecha_desactivacion      DateTime?
  fecha_fin_contrato       DateTime?
  orientacion              String?
  precio_minimo            Decimal?               @db.Decimal(12, 2)
  propietarioId            Int?
  referencia               String?
  sector                   String?
  tiene_area_bbq           Boolean                @default(false)
  tiene_areas_comunales    Boolean                @default(false)
  tiene_ascensor           Boolean                @default(false)
  tiene_balcon             Boolean                @default(false)
  tiene_bodega             Boolean                @default(false)
  tiene_gas_centralizado   Boolean                @default(false)
  tiene_patio              Boolean                @default(false)
  tiene_piscina            Boolean                @default(false)
  tiene_seguridad          Boolean                @default(false)
  tiene_terraza            Boolean                @default(false)
  tipo_comision            String?                @default("porcentaje")
  tipo_contrato            String?
  updatedBy                Int?
  uso_propiedad            UsoPropiedad?
  tiene_cisterna           Boolean                @default(false)
  tiene_lavanderia         Boolean                @default(false)
  fecha_captacion          DateTime?              @default(now())
  unidad_area_construccion String                 @default("m2")
  unidad_area_terreno      String                 @default("m2")
  valor_garantia           Decimal?               @db.Decimal(12, 2)
  documentos               DocumentoPropiedad[]
  favoritos                Favorito[]
  interacciones            InteraccionUsuario[]
  imagenes                 Imagen[]
  negociaciones            Negociacion[]
  agente                   Usuario                @relation(fields: [agenteId], references: [id])
  usuarioDesactivador      Usuario?               @relation("PropiedadDesactivador", fields: [desactivado_por], references: [id])
  propietario              Cliente?               @relation("PropiedadPropietario", fields: [propietarioId], references: [id])
  usuarioActualizador      Usuario?               @relation("PropiedadActualizador", fields: [updatedBy], references: [id])
  propietarios             PropiedadPropietario[]
}

model DocumentoPropiedad {
  id          Int                    @id @default(autoincrement())
  nombre      String
  url         String
  tipo        TipoDocumentoPropiedad
  categoria   CategoriaDocumento
  propiedadId Int
  createdAt   DateTime               @default(now())
  propiedad   Propiedad              @relation(fields: [propiedadId], references: [id])
}

model PropiedadPropietario {
  id           Int       @id @default(autoincrement())
  propiedadId  Int
  clienteId    Int
  porcentaje   Decimal   @default(0) @db.Decimal(5, 2)
  es_principal Boolean   @default(false)
  updatedAt    DateTime  @updatedAt
  createdAt    DateTime  @default(now())
  cliente      Cliente   @relation(fields: [clienteId], references: [id])
  propiedad    Propiedad @relation(fields: [propiedadId], references: [id])

  @@unique([propiedadId, clienteId])
}

model Imagen {
  id          Int       @id @default(autoincrement())
  url         String
  propiedadId Int
  propiedad   Propiedad @relation(fields: [propiedadId], references: [id])
}

model Favorito {
  id          Int       @id @default(autoincrement())
  usuarioId   Int
  propiedadId Int
  createdAt   DateTime  @default(now())
  propiedad   Propiedad @relation(fields: [propiedadId], references: [id])
  usuario     Usuario   @relation(fields: [usuarioId], references: [id])

  @@unique([usuarioId, propiedadId])
}

model InteraccionUsuario {
  id          Int             @id @default(autoincrement())
  usuarioId   Int
  propiedadId Int
  tipo        TipoInteraccion
  valor_peso  Int             // VISTA=1, FAVORITO=5, CONTACTO=10
  fecha       DateTime        @default(now())

  usuario     Usuario         @relation(fields: [usuarioId], references: [id])
  propiedad   Propiedad       @relation(fields: [propiedadId], references: [id])

  @@unique([usuarioId, propiedadId, tipo])
  @@index([usuarioId])
  @@index([propiedadId])
}

model Cliente {
  id                       Int                    @id @default(autoincrement())
  nombre                   String
  telefono                 String
  email                    String?
  tipo_cliente             TipoCliente
  observaciones            String?
  activo                   Boolean                @default(true)
  agenteId                 Int?
  createdAt                DateTime               @default(now())
  updatedAt                DateTime               @updatedAt
  desactivado_por          Int?
  fecha_desactivacion      DateTime?
  cedula                   String?
  estado_civil             EstadoCivil?
  agente                   Usuario?               @relation(fields: [agenteId], references: [id])
  usuario_desactivador     Usuario?               @relation("ClienteDesactivador", fields: [desactivado_por], references: [id])
  documentos               DocumentoCliente[]
  negociaciones            Negociacion[]
  propiedades              Propiedad[]            @relation("PropiedadPropietario")
  participacionPropiedades PropiedadPropietario[]
}

model DocumentoCliente {
  id        Int                  @id @default(autoincrement())
  nombre    String
  url       String
  tipo      TipoDocumentoCliente
  clienteId Int
  createdAt DateTime             @default(now())
  cliente   Cliente              @relation(fields: [clienteId], references: [id])
}

model Negociacion {
  id                  Int                  @id @default(autoincrement())
  clienteId           Int
  propiedadId         Int
  agenteId            Int
  etapa               EtapaNegociacion     @default(interes)
  fecha_inicio        DateTime             @default(now())
  activo              Boolean              @default(true)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  fecha_cambio_etapa  DateTime             @default(now())
  archivosNegociacion ArchivoNegociacion[]
  agente              Usuario              @relation(fields: [agenteId], references: [id])
  cliente             Cliente              @relation(fields: [clienteId], references: [id])
  propiedad           Propiedad            @relation(fields: [propiedadId], references: [id])
  notasInternas       NotaInterna[]
  seguimientos        Seguimiento[]

  @@unique([clienteId, propiedadId])
}

model Seguimiento {
  id            Int             @id @default(autoincrement())
  negociacionId Int
  agenteId      Int
  fecha         DateTime        @default(now())
  comentario    String
  tipo          TipoSeguimiento @default(otro)
  activo        Boolean         @default(true)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  agente        Usuario         @relation(fields: [agenteId], references: [id])
  negociacion   Negociacion     @relation(fields: [negociacionId], references: [id])

  @@map("Seguimiento")
}

model NotaInterna {
  id            Int         @id @default(autoincrement())
  negociacionId Int
  agenteId      Int
  fecha         DateTime    @default(now())
  contenido     String
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  agente        Usuario     @relation(fields: [agenteId], references: [id])
  negociacion   Negociacion @relation(fields: [negociacionId], references: [id])

  @@map("NotaInterna")
}

model ArchivoNegociacion {
  id              Int          @id @default(autoincrement())
  negociacionId   Int
  agenteId        Int
  nombre_archivo  String
  nombre_guardado String
  tipo            TipoArchivo?
  fecha_subida    DateTime     @default(now())
  url             String
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  activo          Boolean      @default(true)
  tamano          Int
  agente          Usuario      @relation(fields: [agenteId], references: [id])
  negociacion     Negociacion  @relation(fields: [negociacionId], references: [id])

  @@map("ArchivoNegociacion")
}

model DocumentoAgente {
  id        Int                 @id @default(autoincrement())
  nombre    String
  url       String
  tipo      TipoDocumentoAgente
  agenteId  Int
  createdAt DateTime            @default(now())
  agente    Usuario             @relation(fields: [agenteId], references: [id])

  @@map("DocumentoAgente")
}

enum Rol {
  cliente
  agente
  admin
}

enum TipoInteraccion {
  VISTA
  FAVORITO
  CONTACTO
}

enum EstadoPropiedad {
  disponible
  vendida
  arrendada
  reservada
  inactiva
}

enum TipoPropiedad {
  casa
  departamento
  terreno
  local_comercial
  finca
  quinta
  suite
  oficina
  bodega_galpon
  edificio
}

enum UsoPropiedad {
  residencial
  comercial
  industrial
  agricola
  turistico
  mixto
}

enum EstadoFisico {
  nueva
  bueno
  regular
  por_remodelar
  en_construccion
}

enum CategoriaDocumento {
  LEGAL
  PROPIETARIO
  COMERCIAL
  TECNICO
  PH
  SERVICIOS
  OTROS
}

enum TipoDocumentoPropiedad {
  ESCRITURA
  CERTIFICADO_GRAVAMEN
  PAGO_PREDIAL
  PLANO
  IRM
  REGLAMENTO_PH
  ALICUOTA
  OTRO
  AUTORIZACION_VENTA
  FICHA_CATASTRAL
  CERTIFICADO_USO_SUELO
  CERTIFICADO_ALICUOTA
  PLANILLA_LUZ
  PLANILLA_AGUA
  PLANILLA_ALICUOTA
  CONTRATO_EXCLUSIVIDAD
  CERTIFICADO_EXPENSAS
}

enum TipoDocumentoCliente {
  CEDULA
  PAPELETA_VOTACION
  PODER
  OTRO
}

enum EstadoCivil {
  SOLTERO
  CASADO
  DIVORCIADO
  VIUDO
  UNION_DE_HECHO
}

enum TipoTransaccion {
  venta
  alquiler
  alquiler_opcion_compra
}

enum Provincia {
  Azuay
  Bolivar
  Canar
  Carchi
  Chimborazo
  Cotopaxi
  El_Oro
  Esmeraldas
  Galapagos
  Guayas
  Imbabura
  Loja
  Los_Rios
  Manabi
  Morona_Santiago
  Napo
  Orellana
  Pastaza
  Pichincha
  Santa_Elena
  Santo_Domingo
  Sucumbios
  Tungurahua
  Zamora_Chinchipe
}

enum TipoCliente {
  comprador
  arrendatario
  propietario
  vendedor
  inversionista
  consultor
  prospecto
}

enum EtapaNegociacion {
  interes
  negociacion
  cierre
  finalizada
  cancelada
}

enum TipoSeguimiento {
  llamada
  visita
  mensaje
  email
  reunion
  documento
  otro
}

enum TipoDocumentoAgente {
  IDENTIFICACION
  CONTRATO
  HOJA_VIDA
  CERTIFICADO
  OTRO
}

enum TipoArchivo {
  contrato
  cedula
  otros
  reserva
  promesa
  minuta
  pago
}
